{
  "name": "repolens-code-parser-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "Out-of-process multi-language code parser for RepoLens indexing. Reads source files, emits {symbols, dependencies} JSON via tree-sitter. Phase 1: TypeScript/JavaScript.",
  "bin": {
    "repolens-parser": "index.js"
  },
  "scripts": {
    "selftest": "node index.js fixtures/ts-sample < fixtures/filelist.json"
  },
  "dependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-c-sharp": "^0.21.3",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-ruby": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2"
  }
}
